WEATHERAI_API_KEY=your_weatherai_api_key
WEATHERAI_BASE_URL=https://api.weather-ai.co
FRONTEND_ORIGIN=http://localhost:3000
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-5-nano
# Optional: override the OpenAI API endpoint (e.g. for a proxy or compatible
# gateway). Leave empty to use the SDK default (https://api.openai.com/v1).
OPENAI_BASE_URL=
# Optional: connection/request timeout (seconds) and retry attempts for the
# OpenAI client used by the chat agent.
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2